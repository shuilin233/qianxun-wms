# ============================================
# 千寻仓库管理系统 — 环境配置模板
# ============================================
# 使用方法：复制本文件为 .env，修改为你的实际配置
#   cp .env.example .env
# ============================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=warehouse

# JWT 配置
JWT_SECRET_KEY=your_random_secret_here
JWT_ACCESS_TOKEN_EXPIRES=604800

# Flask 运行模式
FLASK_ENV=development
FLASK_DEBUG=true
